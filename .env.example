# Directus instance URL — required in all environments
NUXT_PUBLIC_DIRECTUS_URL=https://your-directus.example.com

# Optional public-facing site URL used on printed cards and copied delivery links.
# Set this to your production domain even when developing locally.
# NUXT_PUBLIC_SITE_URL_DISPLAY=https://verycrunchy.com

# Server-side Directus token. Required for local schema scripts and any write-backed
# features such as street-photo delivery intake. Keep this server-only.
# DIRECTUS_TOKEN=your_admin_token_here
